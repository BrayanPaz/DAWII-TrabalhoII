<%-include('../cabecalho.ejs')%>
<h1>Adicionar Aluno</h1>
<div>
    <form method="post" enctype="multipart/form-data">
        <label>Nome:</label>
        <input type="text" name="nome" value="<%= Jogo.nome %>" required>
        <br>
        <label>Gêneros:</label>
        <input type="text" name="generos" value="<%= Jogo.gêneros.join(', ') %>" required>
        <br>
        <label>Preço:</label>
        <input type="number" step="0.01" name="preço" value="<%= Jogo.preço %>" required>
        <br>
        <label>Descrição:</label>
        <input type="text" name="descrição" value="<%= Jogo.descrição %>" required>
        <br>
        <label>Memória RAM Mínima:</label>
        <input type="text" name="minRAM" value="<%= Jogo.minRAM %>" required>
        <br>
        <label>Armazenamento:</label>
        <input type="text" name="armazenamento" value="<%= Jogo.armazenamento %>" required>
        <br>
        <label>Poster:</label>
        <input type="file" name="poster" accept="image/*" value="<%= Jogo.poster %>">
        <br>
        <label>Distribuidora:</label>
        <input type="text" name="distribuidora" value="<%= Jogo.distribuidora %>" required>
        <br>
        <label>Desenvolvedora:</label>
        <input type="text" name="desenvolvedora" value="<%= Jogo.desenvolvedora %>" required>
        <br>
        <label>Data de Lançamento:</label>
        <input type="date" name="dataDeLançamento" value="<%= Jogo.dataDeLançamento %>" required>
        <br>
        <button type="submit">Adicionar</button>
    </form>
</div>
<%-include('../rodape.ejs')%>
