<%-include('../cabecalho.ejs')%>
<h1>Adicionar Aluno</h1>
<div>
    <form method="post" enctype="multipart/form-data">
        <label>Nome:</label>
        <input type="text" name="nome" required>
        <br>
        <label>Gêneros:</label>
        <input type="text" name="generos" required>
        <br>
        <label>Preço:</label>
        <input type="number" step="0.01" name="preço" required>
        <br>
        <label>Descrição:</label>
        <input type="text" name="descrição" required>
        <br>
        <label>Memória RAM Mínima:</label>
        <input type="text" name="minRAM" required>
        <br>
        <label>Armazenamento:</label>
        <input type="text" name="armazenamento" required>
        <br>
        <label>Poster:</label>
        <input type="file" name="poster" accept="image/*">
        <br>
        <label>Distribuidora:</label>
        <input type="text" name="distribuidora" required>
        <br>
        <label>Desenvolvedora:</label>
        <input type="text" name="desenvolvedora" required>
        <br>
        <label>Data de Lançamento:</label>
        <input type="date" name="dataDeLançamento" required>
        <br>
        <button type="submit">Adicionar</button>
    </form>
</div>
<%-include('../rodape.ejs')%>
