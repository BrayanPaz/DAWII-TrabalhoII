<%-include('../cabecalho.ejs')%>
<h1>Editar Distribuidora</h1>
<div>
    <form method="post" enctype="multipart/form-data">
        <input type="hidden" name="id" value="<%=Distribuidora.id%>" required readonly>
        <br>
        <label>Nome:</label>
        <input type="text" name="nome" value="<%=Distribuidora.nome%>" required>
        <br>
        <label>Descrição:</label>
        <input type="text" name="descricao" value="<%=Distribuidora.descricao%>" required>
        <br>
        <label>Website:</label>
        <input type="text" name="website" value="<%=Distribuidora.website%>" required>
        <br>
        <label>País de Origem:</label>
        <input type="text" name="paisDeOrigem" value="<%=Distribuidora.paisDeOrigem%>" required>
        <br>
        <label>Data de Fundação:</label>
        <input type="date" name="dataDeFundacao" value="<%=Distribuidora.dataDeFundacao%>" required>
        <br>
        <label>Logo:</label>
        <input type="file" name="logo" accept="image/*" value="<%=Distribuidora.logo%>">
        <br>
        <button type="submit">Salvar</button>
    </form>
</div>
<%-include('../rodape.ejs')%>